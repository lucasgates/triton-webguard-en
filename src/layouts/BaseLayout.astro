---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = '' } = Astro.props;
const canonicalURL = `https://tritoninfosec.com${canonicalPath}`;
---

<!DOCTYPE html>
<html lang="en">
